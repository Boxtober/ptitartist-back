{
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.fontSize": 14,
  "editor.fontLigatures": false,
  "explorer.autoReveal": true,
  "search.exclude": {
    "**/dist": true,
    "**/node_modules": true
  },
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "prettier.singleQuote": true,  
  "prettier.bracketSameLine": true,
  "git.mergeEditor": true
}