datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  age       Int?
  avatarUrl String?
  createdAt DateTime @default(now())
  images    Image[]  
}

model Image {
  id        String   @id @default(uuid())
  url       String
  description String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}